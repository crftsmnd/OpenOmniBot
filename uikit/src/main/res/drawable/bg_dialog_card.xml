<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 第一层渐变：65.67度角 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:fillAlpha="0.9"
                android:startX="53.5"
                android:startY="105"
                android:endX="160.5"
                android:endY="105"
                >
                <item
                    android:color="#FFFFFF"
                    android:offset="0"
                    />
                <item
                    android:color="#80FFFFFF"
                    android:offset="1"
                    />
            </gradient>
        </shape>
    </item>

    <!-- 第二层渐变：半透明白色叠加 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#ccFFFFFF"
                android:endColor="#ccFFFFFF"
                android:angle="0"
                android:type="linear" />
            <corners android:radius="10dp" />
            <stroke
                android:color="#EEEEEE"
                android:width="1dp" />
        </shape>
    </item>
</layer-list>
