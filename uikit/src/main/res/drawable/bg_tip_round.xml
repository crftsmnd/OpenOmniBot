<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Layer 1: Border Gradient (Acts as background, revealed at edges) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <gradient
                android:angle="45"
                android:startColor="#E38BEAFF"
                android:centerColor="#00AEFF"
                android:endColor="#B38BEAFF"
                android:type="linear" />
        </shape>
    </item>

    <!-- Layer 2: Base Content Gradient (Inset by border width 1dp) -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="49dp" />
            <gradient
                android:angle="45"
                android:centerColor="#FFFFFF"
                android:endColor="#a100AEFF"
                android:startColor="#FFFFFF"
                android:type="linear" />
        </shape>
    </item>

    <!-- Layer 3: Overlay (Inset by border width 1dp) -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="49dp" />
            <solid android:color="#CCFFFFFF" />
        </shape>
    </item>
</layer-list>
