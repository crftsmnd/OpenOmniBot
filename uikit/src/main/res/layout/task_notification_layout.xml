<?xml version="1.0" encoding="utf-8"?><!--
  Note: The button icons (@drawable/ic_notification_cancel and @drawable/ic_notification_execute) are placeholders.
  Please replace them with your actual drawable resources to match the design.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <TextView
        android:id="@+id/time_text"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginStart="8dp"
        android:gravity="center_vertical"
        android:text="29:32 后将执行"
        android:textAppearance="@android:style/TextAppearance.Material.Notification.Time" />


    <LinearLayout
        android:id="@+id/llContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/time_text"
        android:layout_marginStart="12dp"

        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/task_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="米乳燕麦拿铁"
            android:textAppearance="@android:style/TextAppearance.Material.Notification.Title" />

        <TextView
            android:id="@+id/task_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="中杯, 温热, 标准糖"
            android:textAppearance="@android:style/TextAppearance.Material.Notification.Line2" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/action_buttons"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_below="@id/llContent"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/cancel_button"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:background="@drawable/notify_background"

            android:drawableLeft="@mipmap/ic_notification_cancel"
            android:drawablePadding="4dp"
            android:gravity="center_vertical"
            android:minWidth="60dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="取消"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/execute_button"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/notify_background"
            android:drawableLeft="@mipmap/ic_notification_execute"
            android:drawablePadding="4dp"

            android:gravity="center_vertical"
            android:minWidth="60dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="执行"
            android:textSize="12sp" />
    </LinearLayout>

</RelativeLayout>