<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许本地/局域网明文通信（OpenClaw 媒体与网关多为 HTTP） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
