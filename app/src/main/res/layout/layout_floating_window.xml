<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#33ff3300"
    android:gravity="center"
    android:minHeight="40dp"
    android:orientation="vertical"
    android:padding="10dp">
    <!--    展开-->

    <TextView
        android:id="@+id/tv_expand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="展开⬆️"
        android:textColor="#fff"
        android:textSize="16sp" />


    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/ll_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_data_image"
                android:layout_width="400dp"
                android:scaleType="centerInside"
                android:layout_height="600dp"
                android:visibility="gone"
                android:contentDescription="图片" />

            <EditText
                android:id="@+id/edt_id"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:hint="请输入nodeID" />

            <EditText
                android:id="@+id/edt_function"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:hint="请输入方法名称" />

            <EditText
                android:id="@+id/edt_x"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:hint="请输入x坐标" />

            <EditText
                android:id="@+id/edt_y"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:hint="请输入y坐标" />

            <EditText
                android:id="@+id/edt_direction"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:hint="请输入滑动距离" />

            <EditText
                android:id="@+id/edt_distance"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:hint="distance" />



        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="执行" />
    <Button
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="关闭" />
</LinearLayout>
